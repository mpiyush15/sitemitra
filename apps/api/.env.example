# Copy to .env and fill in values

NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/sitemitra

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx

STANDARD_PLAN_AMOUNT_PAISE=199900
STANDARD_PLAN_DURATION_DAYS=365

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# Optional: AWS S3 for hero banners (Super Admin uploads). Bucket + AWS keys required to enable uploads.
# If S3_PUBLIC_BASE_URL is empty, URLs default to https://{S3_BUCKET_NAME}.s3.{AWS_REGION}.amazonaws.com
# S3_PREFIX example: site-mitra/  → keys like site-mitra/banners/<uuid>.webp
# S3_ENDPOINT: leave blank for AWS; set for R2/MinIO (path-style).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=
# S3_PREFIX=site-mitra/
# S3_PUBLIC_BASE_URL=
# S3_ENDPOINT=

# apps/web — Next/Image remote host (hostname only, no protocol):
# NEXT_PUBLIC_S3_IMAGE_HOST=your-bucket.s3.ap-south-1.amazonaws.com
